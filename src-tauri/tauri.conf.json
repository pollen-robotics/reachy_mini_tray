{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Reachy Mini",
  "version": "0.1.1",
  "identifier": "com.pollen-robotics.reachy-mini-daemon",
  "build": {
    "frontendDist": "../ui"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [],
    "security": {
      "csp": null
    },
    "macOSPrivateApi": true
  },
  "bundle": {
    "active": true,
    "createUpdaterArtifacts": true,
    "targets": ["app", "dmg", "nsis", "deb", "appimage"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "externalBin": [
      "binaries/uv-trampoline"
    ],
    "resources": [
      "python-entitlements.plist"
    ],
    "macOS": {
      "minimumSystemVersion": "11.0",
      "infoPlist": "Info.plist"
    }
  },
  "plugins": {
    "updater": {
      "active": true,
      "endpoints": [
        "https://github.com/pollen-robotics/reachy_mini_tray/releases/latest/download/latest.json"
      ],
      "dialog": false,
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEY0QTEwRkE1QjNCNzE4REEKUldUYUdMZXpwUStoOUtTcmV5SGdqTXVuMHZJMWRIVklYb2FoMlVBWW1ERGh4N2dqQ1hING1RdFYK",
      "windows": {
        "installMode": "passive"
      }
    }
  }
}
